{
  "buildCommand": "pnpm build && cp dist/bookmarklet.global.js landing/",
  "outputDirectory": "landing",
  "headers": [
    {
      "source": "/bookmarklet.global.js",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Cache-Control", "value": "public, max-age=300" }
      ]
    }
  ]
}
